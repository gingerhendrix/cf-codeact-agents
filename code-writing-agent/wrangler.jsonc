/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "linear-agent",
	"main": "src/server.ts",
	"compatibility_date": "2025-08-03",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"ai": {
		"binding": "AI"
	},
	"assets": {
		"directory": "public"
	},
  "browser": {
    "binding": "BROWSER"
  },
	"durable_objects": {
		"bindings": [
			{
				"name": "ExecutionChat",
				"class_name": "ExecutionChatAgent"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"ExecutionChatAgent"
			]
		}
	],
	"observability": {
		"enabled": true
	},
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
	"services": [
		{
			"binding": "FETCH_PROXY",
			"service": "linear-agent",
			"entrypoint": "FetchProxy"
		}
	]
}
